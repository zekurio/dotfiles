  },

  "network": {
    "format-wifi": "ï‡«  {ifname}",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "tooltip-format-wifi": "Network: <b>{essid}</b>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>\n<span foreground='#eed49f'>ï€™ {bandwidthDownBytes}</span> <span foreground='#b7bdf8'>ï‚“ {bandwidthUpBytes}</span>",
