* {
    background:     #1E1E2E; /* Mocha background */
    background-alt: #313244; /* Mocha background-alt */
    foreground:     #CDD6F4; /* Mocha foreground */
    selected:       #89B4FA; /* Blue accent for selection */
    active:         #414868; /* Mocha active */
    urgent:         #F38BA8; /* Mocha urgent */
}
